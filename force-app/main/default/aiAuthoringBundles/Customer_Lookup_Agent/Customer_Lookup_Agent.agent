config:
  developer_name: "Customer_Lookup_Agent"
  agent_label: "Customer Lookup Agent"
  description: "An internal employee agent that helps staff search for customer contact records by last name, view full details, update existing records, or create new customers."
  agent_type: "AgentforceEmployeeAgent"

variables:
  last_name_query: mutable string = ""
  contact_summary: mutable string = ""
  contact_ids: mutable string = ""
  found: mutable boolean = False
  selected_contact_id: mutable string = ""
  update_result: mutable string = ""

system:
  messages:
    welcome: "Hi! I'm your Customer Lookup Agent. I can help you search for customers, view their details, and update their records. Just say 'Find a customer' to get started!"
    error: "Sorry, something went wrong. Please try again."
  instructions: "You are an internal employee agent that helps staff find and manage customer contact records. You are professional, clear, and concise in your responses."

language:
  default_locale: "en_US"
  all_additional_locales: False

start_agent topic_selector:
  label: "Topic Selector"
  description: "Welcome the user and route to the appropriate topic based on their request."

  reasoning:
    instructions: |
      Welcome the user and help them with their request.
      Route to the appropriate topic based on what they want to do.
    actions:
      go_to_lookup: @utils.transition to @topic.lookup_customer
        description: "User wants to find or look up a customer."
      go_to_create: @utils.transition to @topic.create_customer
        description: "User wants to create a new customer."
      go_to_off_topic: @utils.transition to @topic.off_topic
        description: "Request is not related to customer management."

topic lookup_customer:
  label: "Lookup Customer"
  description: "Search for customer contact records by last name. Displays all matching records with full details. If no records found, says so and offers to create a new customer."

  actions:
    query_contacts:
      description: "Searches Salesforce Contact records by last name and returns a formatted list of matching customers with all their details."
      inputs:
        lastName: string
          description: "The customer's last name to search for."
          is_required: True
          is_user_input: True
      outputs:
        found: boolean
          description: "True if one or more contacts were found, False otherwise."
        contactSummary: string
          description: "Formatted summary of all matching contact records."
        contactIds: string
          description: "Comma-separated list of matching Contact record IDs."
          filter_from_agent: True
      target: "apex://QueryContactAction"

  reasoning:
    instructions: ->
      if @variables.contact_summary != "":
        | Here are the results of your search:
        | {!@variables.contact_summary}
        | What would you like to do next? You can:
        | - Update a customer record (tell me the Record ID and what to change)
        | - Search for another customer
        | - Create a new customer

      | Please provide the last name of the customer you want to find.
    actions:
      search: @actions.query_contacts
        with lastName = ...
        set @variables.found = @outputs.found
        set @variables.contact_summary = @outputs.contactSummary
        set @variables.contact_ids = @outputs.contactIds
      go_to_update: @utils.transition to @topic.update_customer
        description: "User wants to update one of the displayed customer records."
      go_to_create: @utils.transition to @topic.create_customer
        description: "User wants to create a new customer after seeing results."
      go_to_search_again: @utils.transition to @topic.lookup_customer
        description: "User wants to search for a different customer."

topic update_customer:
  label: "Update Customer"
  description: "Updates an existing customer contact record. Asks the user which fields to change, confirms the changes, then saves the updated record and displays the confirmation."

  actions:
    update_contact:
      description: "Updates an existing Contact record in Salesforce with new field values provided by the user."
      inputs:
        contactId: string
          description: "The Salesforce Record ID of the contact to update."
          is_required: True
          is_user_input: True
        firstName: string
          description: "Updated first name (leave blank to keep existing)."
          is_user_input: True
        lastName: string
          description: "Updated last name (leave blank to keep existing)."
          is_user_input: True
        email: string
          description: "Updated email address (leave blank to keep existing)."
          is_user_input: True
        phone: string
          description: "Updated phone number (leave blank to keep existing)."
          is_user_input: True
        mailingStreet: string
          description: "Updated street address (leave blank to keep existing)."
          is_user_input: True
        mailingCity: string
          description: "Updated city (leave blank to keep existing)."
          is_user_input: True
        mailingState: string
          description: "Updated state (leave blank to keep existing)."
          is_user_input: True
        mailingPostalCode: string
          description: "Updated postal/zip code (leave blank to keep existing)."
          is_user_input: True
        mailingCountry: string
          description: "Updated country (leave blank to keep existing)."
          is_user_input: True
      outputs:
        resultMessage: string
          description: "Confirmation message showing the updated record details."
      target: "apex://UpdateContactAction"

  reasoning:
    instructions: ->
      if @variables.update_result != "":
        | {!@variables.update_result}
        | What would you like to do next?
        | - Search for another customer
        | - Create a new customer

      | Please provide the Record ID of the customer you want to update, and tell me which fields you'd like to change (name, email, phone, or address).
      | You can find the Record ID in the search results above.
    actions:
      update: @actions.update_contact
        with contactId = ...
        set @variables.update_result = @outputs.resultMessage
      go_to_lookup: @utils.transition to @topic.lookup_customer
        description: "User wants to search for another customer after updating."
      go_to_create: @utils.transition to @topic.create_customer
        description: "User wants to create a new customer."

topic create_customer:
  label: "Create Customer"
  description: "Creates a new customer contact record by collecting all required details from the user."

  actions:
    create_contact:
      description: "Creates a new Contact record in Salesforce with the provided customer details."
      inputs:
        firstName: string
          description: "Customer's first name."
          is_required: True
          is_user_input: True
        lastName: string
          description: "Customer's last name."
          is_required: True
          is_user_input: True
        email: string
          description: "Customer's email address."
          is_user_input: True
        phone: string
          description: "Customer's phone number."
          is_user_input: True
        mailingStreet: string
          description: "Customer's street address."
          is_user_input: True
        mailingCity: string
          description: "Customer's city."
          is_user_input: True
        mailingState: string
          description: "Customer's state."
          is_user_input: True
        mailingPostalCode: string
          description: "Customer's postal/zip code."
          is_user_input: True
        mailingCountry: string
          description: "Customer's country."
          is_user_input: True
      outputs:
        resultMessage: string
          description: "Confirmation message with the newly created contact details and Record ID."
      target: "apex://CreateContactAction"

  reasoning:
    instructions: |
      Help the user create a new customer contact record.
      Collect the following details step by step:
      1. First name and last name (required).
      2. Email address.
      3. Phone number.
      4. Shipping address: street, city, state, postal code, and country.
      Confirm all details with the user before saving.
      After saving, display the full confirmation message including the Record ID.
    actions:
      create: @actions.create_contact
        with firstName = ...
        with lastName = ...
      go_to_lookup: @utils.transition to @topic.lookup_customer
        description: "User wants to search for a customer after creating one."

topic off_topic:
  label: "Off Topic"
  description: "Redirect conversation when the user request is not related to customer management."

  reasoning:
    instructions: |
      Politely let the user know you can only help with customer record management.
      Offer to help them find a customer, update a customer, or create a new customer.
